#!/usr/bin/env bash
# ============================================================
# Script: md2pdf
# Descripción: Wrapper para pandoc con batch processing y UTF-8 BOM handling
# Autor: Donshu
# Contacto: donshu.apps@gmail.com
# GitHub: https://github.com/donshuapps-cloud
# Versión: 2.2.0 (Verificación completa de dependencias)
# ============================================================
set -euo pipefail
# ============================================================
# CONFIGURACIÓN POR DEFECTO
# ============================================================
DEFAULT_FONT="Arial"
DEFAULT_ENGINE="xelatex"
DEFAULT_TEMPLATE=""
DEFAULT_CSS=""
DEFAULT_OUTPUT_DIR="."
# Colores para output
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
NC='\033[0m'
# Contadores para batch processing
TOTAL_FILES=0
SUCCESS_COUNT=0
FAIL_COUNT=0
# ============================================================
# FUNCIONES DE UTILIDAD
# ============================================================
print_usage() {
    cat << EOF
╔══════════════════════════════════════════════════════════════╗
║                    md2pdf - Markdown to PDF                  ║
║                    Versión 2.2.0 - Donshu Apps               ║
╚══════════════════════════════════════════════════════════════╝
Uso: $(basename "$0") [OPCIONES] <archivo.md|directorio>
Convierte archivos Markdown a PDF usando pandoc con engine XeLaTeX.
OPCIONES:
    -o, --output DIR      Directorio de salida (default: directorio actual)
    -f, --font FUENTE     Fuente principal (default: $DEFAULT_FONT)
    -e, --engine ENGINE   Engine de LaTeX (default: $DEFAULT_ENGINE)
                          Opciones: xelatex, lualatex, pdflatex, weasyprint
    -t, --template ARCH   Plantilla de pandoc personalizada
    -c, --css ARCH        Hoja de estilos CSS
    -b, --batch           Modo lote: procesa todos los archivos .md especificados
    --no-bom              Deshabilitar eliminación de BOM
    --skip-svg-check      Saltar verificación de dependencias SVG
    --check-deps          Verificar dependencias y salir
    --debug               Mostrar errores completos de pandoc
    -v, --verbose         Modo verbose (muestra comandos ejecutados)
    -q, --quiet           Modo silencioso (solo errores)
    -h, --help            Muestra esta ayuda
DEPENDENCIAS REQUERIDAS:
    ✓ pandoc              Conversor principal
    ✓ xelatex/lualatex    Engine LaTeX (según elección)
    ⚠ rsvg-convert       Conversión de imágenes SVG (opcional)
    Instalación de dependencias faltantes:
        Ubuntu/Debian: sudo apt install pandoc texlive-xetex librsvg2-bin xxd
        macOS:         brew install pandoc basictex librsvg
        Arch Linux:    sudo pacman -S pandoc texlive-core librsvg
MODOS DE OPERACIÓN:
    # Verificar dependencias
    $(basename "$0") --check-deps
    # Modo individual
    $(basename "$0") documento.md
    $(basename "$0") -o ./pdfs -f "Times New Roman" documento.md
    # Modo batch (archivos específicos)
    $(basename "$0") --batch archivo1.md archivo2.md archivo3.md
    # Modo batch (directorio)
    $(basename "$0") --batch ./documentos/ -o ./pdfs/
    # Modo batch (wildcard con shell expansion)
    $(basename "$0") --batch docs/*.md
EJEMPLOS:
    # Verificar entorno
    $(basename "$0") --check-deps
    # Conversión básica
    $(basename "$0") README.md
    # Batch con directorio
    $(basename "$0") --batch docs/ -o pdfs/ -f "Times New Roman"
    # Usar engine alternativo para mejor soporte SVG
    $(basename "$0") -e lualatex documento-con-svg.md
EOF
}
log_info() {
    [[ "${QUIET:-false}" != true ]] && echo -e "${GREEN}[INFO]${NC} $1"
}
log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1" >&2
}
log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}
log_debug() {
    if [[ "${DEBUG:-false}" == true ]]; then
        echo -e "${BLUE}[DEBUG]${NC} $1" >&2
    fi
}
log_batch_progress() {
    local current=$1
    local total=$2
    local filename=$3
    local status=$4
    local status_color=""
    local status_text=""
    case "$status" in
        success)
            status_color="$GREEN"
            status_text="✓"
            ;;
        fail)
            status_color="$RED"
            status_text="✗"
            ;;
        processing)
            status_color="$BLUE"
            status_text="▶"
            ;;
    esac
    echo -e "${status_color}[${current}/${total}] ${status_text}${NC} ${filename}"
}
print_dependency_report() {
    echo ""
    echo -e "${CYAN}════════════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}              REPORTE DE DEPENDENCIAS - md2pdf                  ${NC}"
    echo -e "${CYAN}════════════════════════════════════════════════════════════════${NC}"
    echo ""
    # Pandoc
    if command -v pandoc &> /dev/null; then
        local pandoc_version=$(pandoc --version | head -n1)
        echo -e "  ${GREEN}✓${NC} pandoc: ${pandoc_version}"
    else
        echo -e "  ${RED}✗${NC} pandoc: NO INSTALADO"
        echo -e "     Instalación: sudo apt install pandoc"
    fi
    # Engine LaTeX
    local engine="${ENGINE:-$DEFAULT_ENGINE}"
    if command -v "$engine" &> /dev/null; then
        echo -e "  ${GREEN}✓${NC} $engine: disponible"
    else
        echo -e "  ${RED}✗${NC} $engine: NO INSTALADO"
        echo -e "     Instalación: sudo apt install texlive-xetex"
    fi
    # rsvg-convert para SVG
    if command -v rsvg-convert &> /dev/null; then
        local rsvg_version=$(rsvg-convert --version 2>/dev/null | head -n1)
        echo -e "  ${GREEN}✓${NC} rsvg-convert: ${rsvg_version:-disponible}"
    else
        echo -e "  ${YELLOW}⚠${NC} rsvg-convert: NO INSTALADO (opcional para imágenes SVG)"
        echo -e "     Instalación: sudo apt install librsvg2-bin"
    fi
    # xxd para BOM detection
    if command -v xxd &> /dev/null; then
        echo -e "  ${GREEN}✓${NC} xxd: disponible (detección UTF-8 BOM)"
    else
        echo -e "  ${YELLOW}⚠${NC} xxd: NO INSTALADO (detección BOM limitada)"
        echo -e "     Instalación: sudo apt install xxd"
    fi
    echo ""
    echo -e "${CYAN}════════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${GREEN}Comando para instalar todas las dependencias:${NC}"
    echo -e "  ${BLUE}sudo apt update && sudo apt install pandoc texlive-xetex librsvg2-bin xxd${NC}"
    echo ""
    # Recomendaciones
    if ! command -v rsvg-convert &> /dev/null; then
        echo -e "${YELLOW}⚠ NOTA:${NC} Sin rsvg-convert, los documentos con imágenes SVG fallarán."
        echo -e "  Para documentos con SVG, considera:"
        echo -e "    1. Instalar rsvg-convert: ${BLUE}sudo apt install librsvg2-bin${NC}"
        echo -e "    2. Usar engine lualatex: ${BLUE}md2pdf -e lualatex documento.md${NC}"
        echo -e "    3. Omitir verificación: ${BLUE}md2pdf --skip-svg-check documento.md${NC}"
    fi
    echo ""
}
# ============================================================
# MANEJO DE UTF-8 BOM
# ============================================================
remove_bom() {
    local input_file="$1"
    local temp_file="$2"
    # Detectar y eliminar BOM si existe
    if [[ "$(head -c 3 "$input_file" | xxd -p 2>/dev/null)" == "efbbbf" ]]; then
        log_debug "BOM detectado en $input_file - eliminando..."
        tail -c +4 "$input_file" > "$temp_file"
        return 0
    else
        # Sin BOM, copiar archivo original
        cp "$input_file" "$temp_file"
        return 0
    fi
}
# ============================================================
# VALIDACIÓN DE DEPENDENCIAS
# ============================================================
check_dependencies() {
    local missing=0
    # Verificar pandoc
    if ! command -v pandoc &> /dev/null; then
        log_error "pandoc no está instalado."
        log_error "Instalación: sudo apt install pandoc"
        missing=1
    fi
    # Verificar engine LaTeX
    if [[ "${CHECK_LATEX:-true}" == true ]] && [[ -n "${ENGINE:-}" ]]; then
        case "$ENGINE" in
            xelatex|lualatex|pdflatex)
                if ! command -v "$ENGINE" &> /dev/null; then
                    log_error "$ENGINE no está disponible."
                    log_error "Instalación: sudo apt install texlive-xetex"
                    missing=1
                fi
                ;;
        esac
    fi
    # Verificar rsvg-convert para SVG (solo warning)
    if [[ "${SKIP_SVG_CHECK:-false}" != true ]] && [[ "${CHECK_LATEX:-true}" == true ]]; then
        if ! command -v rsvg-convert &> /dev/null; then
            log_warn "rsvg-convert no está instalado (necesario para imágenes SVG)"
            log_warn "Instalación: sudo apt install librsvg2-bin"
            echo ""
        fi
    fi
    # Verificar xxd para detección de BOM
    if ! command -v xxd &> /dev/null; then
        if [[ "${NO_BOM:-false}" != true ]]; then
            log_warn "xxd no está instalado. La detección de BOM estará deshabilitada."
            log_warn "Instalación: sudo apt install xxd"
        fi
        BOM_DETECTION=false
    else
        BOM_DETECTION=true
    fi
    # Si hay dependencias críticas faltantes, salir
    if [[ $missing -eq 1 ]]; then
        log_error "Faltan dependencias críticas. Abortando."
        echo ""
        print_dependency_report
        exit 1
    fi
    return 0
}
# ============================================================
# FUNCIÓN PRINCIPAL DE CONVERSIÓN
# ============================================================
convert_md_to_pdf() {
    local input_file="$1"
    local output_dir="$2"
    local output_filename
    local temp_file=""
    local use_temp=false
    # Validar archivo de entrada
    if [[ ! -f "$input_file" ]]; then
        log_error "Archivo no encontrado: $input_file"
        return 1
    fi
    # Validar extensión (warning, no error)
    if [[ ! "$input_file" =~ \.md$ && ! "$input_file" =~ \.markdown$ ]]; then
        log_warn "Extensión inusual: $input_file (se intentará convertir)"
    fi
    # Crear directorio de salida si no existe
    if [[ ! -d "$output_dir" ]]; then
        mkdir -p "$output_dir" 2>/dev/null || {
            log_error "No se pudo crear el directorio: $output_dir"
            return 1
        }
    fi
    # Generar nombre de salida
    local basename_input
    basename_input=$(basename "$input_file")
    basename_input="${basename_input%.md}"
    basename_input="${basename_input%.markdown}"
    output_filename="$output_dir/${basename_input}.pdf"
    # Manejo de BOM
    if [[ "$BOM_DETECTION" == true ]] && [[ "${NO_BOM:-false}" != true ]]; then
        temp_file=$(mktemp)
        if remove_bom "$input_file" "$temp_file"; then
            input_file="$temp_file"
            use_temp=true
            log_debug "Usando archivo temporal: $temp_file"
        else
            log_warn "Error procesando BOM, usando archivo original"
            rm -f "$temp_file"
            use_temp=false
        fi
    fi
    # Construir comando pandoc
    local pandoc_args=(
        "$input_file"
        -o "$output_filename"
        --pdf-engine="$ENGINE"
        -V "mainfont=$FONT"
        -V "geometry:margin=1in"
        -V "geometry:paper=a4paper"
    )
    # Añadir plantilla si se especificó
    if [[ -n "${TEMPLATE:-}" ]] && [[ -f "$TEMPLATE" ]]; then
        pandoc_args+=(--template="$TEMPLATE")
    elif [[ -n "${TEMPLATE:-}" ]]; then
        log_warn "Plantilla no encontrada: $TEMPLATE, se omitirá"
    fi
    # Añadir CSS si se especificó
    if [[ -n "${CSS:-}" ]] && [[ -f "$CSS" ]]; then
        pandoc_args+=(--css="$CSS")
    elif [[ -n "${CSS:-}" ]]; then
        log_warn "CSS no encontrado: $CSS, se omitirá"
    fi
    # Modo verbose
    if [[ "${VERBOSE:-false}" == true ]]; then
        log_info "Ejecutando: pandoc ${pandoc_args[*]}"
    fi
    # Ejecutar conversión
    local pandoc_exit_code
    if [[ "${DEBUG:-false}" == true ]]; then
        pandoc "${pandoc_args[@]}"
        pandoc_exit_code=$?
    else
        pandoc "${pandoc_args[@]}" 2>/dev/null
        pandoc_exit_code=$?
    fi
    # Limpiar archivo temporal
    if [[ "$use_temp" == true ]] && [[ -f "$temp_file" ]]; then
        rm -f "$temp_file"
        log_debug "Archivo temporal eliminado: $temp_file"
    fi
    if [[ $pandoc_exit_code -eq 0 ]]; then
        if [[ "${QUIET:-false}" != true ]]; then
            local file_size
            file_size=$(du -h "$output_filename" 2>/dev/null | cut -f1)
            echo -e "  ${GREEN}✓${NC} $output_filename ${YELLOW}($file_size)${NC}"
        fi
        return 0
    else
        log_error "Conversión fallida: $input_file"
        if [[ "${DEBUG:-false}" != true ]]; then
            log_error "Ejecuta con --debug para ver el error completo"
        fi
        return 1
    fi
}
# ============================================================
# PROCESAMIENTO BATCH
# ============================================================
process_batch() {
    local files=()
    local output_dir="$DEFAULT_OUTPUT_DIR"
    local positional_args=()
    while [[ $# -gt 0 ]]; do
        case $1 in
            -o|--output)
                output_dir="$2"
                shift 2
                ;;
            -f|--font)
                FONT="$2"
                shift 2
                ;;
            -e|--engine)
                ENGINE="$2"
                shift 2
                ;;
            -t|--template)
                TEMPLATE="$2"
                shift 2
                ;;
            -c|--css)
                CSS="$2"
                shift 2
                ;;
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            -q|--quiet)
                QUIET=true
                shift
                ;;
            --no-bom)
                NO_BOM=true
                shift
                ;;
            --skip-svg-check)
                SKIP_SVG_CHECK=true
                shift
                ;;
            --debug)
                DEBUG=true
                shift
                ;;
            *)
                positional_args+=("$1")
                shift
                ;;
        esac
    done
    # Procesar argumentos posicionales
    for item in "${positional_args[@]}"; do
        if [[ -d "$item" ]]; then
            while IFS= read -r -d '' file; do
                files+=("$file")
            done < <(find "$item" -name "*.md" -type f -print0 2>/dev/null || true)
        elif [[ -f "$item" ]]; then
            files+=("$item")
        else
            log_warn "Ignorando: $item (no es archivo ni directorio válido)"
        fi
    done
    TOTAL_FILES=${#files[@]}
    if [[ $TOTAL_FILES -eq 0 ]]; then
        log_error "No se encontraron archivos .md para procesar"
        return 1
    fi
    log_info "Procesando $TOTAL_FILES archivo(s) en modo batch..."
    echo ""
    local current=0
    for file in "${files[@]}"; do
        current=$((current + 1))
        log_batch_progress $current $TOTAL_FILES "$(basename "$file")" "processing"
        if convert_md_to_pdf "$file" "$output_dir"; then
            SUCCESS_COUNT=$((SUCCESS_COUNT + 1))
            log_batch_progress $current $TOTAL_FILES "$(basename "$file")" "success"
        else
            FAIL_COUNT=$((FAIL_COUNT + 1))
            log_batch_progress $current $TOTAL_FILES "$(basename "$file")" "fail"
        fi
        echo ""
    done
    echo ""
    log_info "=== RESUMEN BATCH ==="
    echo -e "  ${GREEN}Éxitos:${NC} $SUCCESS_COUNT"
    echo -e "  ${RED}Fallos:${NC} $FAIL_COUNT"
    echo -e "  Total:  $TOTAL_FILES"
    [[ $FAIL_COUNT -eq 0 ]] && return 0 || return 1
}
# ============================================================
# PROCESAMIENTO INDIVIDUAL
# ============================================================
process_single() {
    local input_file=""
    while [[ $# -gt 0 ]]; do
        case $1 in
            -o|--output)
                OUTPUT_DIR="$2"
                shift 2
                ;;
            -f|--font)
                FONT="$2"
                shift 2
                ;;
            -e|--engine)
                ENGINE="$2"
                shift 2
                ;;
            -t|--template)
                TEMPLATE="$2"
                shift 2
                ;;
            -c|--css)
                CSS="$2"
                shift 2
                ;;
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            -q|--quiet)
                QUIET=true
                shift
                ;;
            --no-bom)
                NO_BOM=true
                shift
                ;;
            --skip-svg-check)
                SKIP_SVG_CHECK=true
                shift
                ;;
            --debug)
                DEBUG=true
                shift
                ;;
            *)
                if [[ -z "$input_file" ]]; then
                    input_file="$1"
                fi
                shift
                ;;
        esac
    done
    if [[ -z "$input_file" ]]; then
        log_error "No se especificó archivo de entrada"
        print_usage
        exit 1
    fi
    convert_md_to_pdf "$input_file" "$OUTPUT_DIR"
    return $?
}
# ============================================================
# PROCESAMIENTO PRINCIPAL
# ============================================================
main() {
    # Variables por defecto
    FONT="$DEFAULT_FONT"
    ENGINE="$DEFAULT_ENGINE"
    TEMPLATE="$DEFAULT_TEMPLATE"
    CSS="$DEFAULT_CSS"
    OUTPUT_DIR="$DEFAULT_OUTPUT_DIR"
    VERBOSE=false
    QUIET=false
    BATCH_MODE=false
    NO_BOM=false
    DEBUG=false
    SKIP_SVG_CHECK=false
    CHECK_DEPS_ONLY=false
    # Sin argumentos: mostrar ayuda
    if [[ $# -eq 0 ]]; then
        print_usage
        exit 0
    fi
    # Verificar si hay --help en cualquier posición
    for arg in "$@"; do
        if [[ "$arg" == "-h" ]] || [[ "$arg" == "--help" ]]; then
            print_usage
            exit 0
        fi
    done
    # Verificar si es solo check de dependencias
    for arg in "$@"; do
        if [[ "$arg" == "--check-deps" ]]; then
            CHECK_DEPS_ONLY=true
            break
        fi
    done
    # Si es solo check de dependencias, mostrar reporte y salir
    if [[ "$CHECK_DEPS_ONLY" == true ]]; then
        print_dependency_report
        exit 0
    fi
    # Detectar modo batch
    for arg in "$@"; do
        if [[ "$arg" == "--batch" ]] || [[ "$arg" == "-b" ]]; then
            BATCH_MODE=true
            break
        fi
    done
    # Si es batch, filtrar el flag
    if [[ "$BATCH_MODE" == true ]]; then
        local filtered_args=()
        for arg in "$@"; do
            if [[ "$arg" != "--batch" ]] && [[ "$arg" != "-b" ]]; then
                filtered_args+=("$arg")
            fi
        done
        set -- "${filtered_args[@]}"
    fi
    # Validar dependencias
    CHECK_LATEX=true
    check_dependencies
    # Ejecutar según modo
    if [[ "$BATCH_MODE" == true ]]; then
        process_batch "$@"
    else
        process_single "$@"
    fi
}
# ============================================================
# EJECUCIÓN
# ============================================================
main "$@"
